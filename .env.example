# ─── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
# Supabase's new-format publishable key (sb_publishable_…). Legacy
# NEXT_PUBLIC_SUPABASE_ANON_KEY is accepted as a fallback.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only secret key (sb_secret_…). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=accreditation-docs
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=accreditation-docs

# ─── Database (Supabase Postgres) ────────────────────────────
DATABASE_URL=
DIRECT_DATABASE_URL=

# ─── Azure Document Intelligence ─────────────────────────────
AZURE_DI_ENDPOINT=
AZURE_DI_KEY=

# ─── OpenRouter (optional — enables AI-assisted eligibility summary) ──
# Leave blank to fall back to deterministic rule-only summary
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=
